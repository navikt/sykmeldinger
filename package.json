{
    "name": "sykmeldinger-root",
    "version": "2.0.0",
    "private": true,
    "packageManager": "yarn@4.2.2",
    "workspaces": [
        "workspaces/*"
    ],
    "engines": {
        "node": "20"
    },
    "scripts": {
        "dev": "yarn workspace sykmeldinger-next dev",
        "start:e2e": "yarn workspace sykmeldinger-next start:e2e",
        "build": "yarn workspace sykmeldinger-next build",
        "build:e2e": "./scripts/build-e2e.sh",
        "test": "yarn workspaces foreach -Apti run test",
        "e2e": "playwright test",
        "e2e:dev": "yarn e2e --ui",
        "lint": "next lint",
        "format": "prettier --write 'src/**/**.{ts,tsx,js,jsx}'",
        "report-debt": "scripts/debt.sh",
        "prepare": "husky"
    },
    "devDependencies": {
        "@axe-core/playwright": "^4.9.1",
        "@navikt/eslint-config-teamsykmelding": "^6.2.0",
        "@playwright/test": "^1.44.1",
        "@types/http-proxy": "^1.17.14",
        "eslint": "8.57.0",
        "http-proxy": "^1.18.1",
        "husky": "^9.0.11",
        "lint-staged": "^15.2.4",
        "playwright-core": "1.44.1",
        "prettier": "^3.2.5",
        "prettier-plugin-tailwindcss": "^0.5.14",
        "typescript": "^5.4.5"
    },
    "prettier": "@navikt/eslint-config-teamsykmelding/prettier",
    "resolutions": {
        "eslint-plugin-react-hooks": "5.0.0-canary-7118f5dd7-20230705"
    }
}
